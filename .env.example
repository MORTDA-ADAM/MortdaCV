# Copy this file to .env and fill in real values. Never commit .env.

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Admin login username
ADMIN_USERNAME=admin

# Bcrypt hash of the admin password. Generate with:
#   npm run hash-password -- "your-password-here"
# Never put the plaintext password here.
ADMIN_PASSWORD_HASH=

# Port the server listens on
PORT=3000

# Set to "production" when deployed behind HTTPS. Enables secure cookies.
NODE_ENV=development
